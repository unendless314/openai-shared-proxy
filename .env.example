HOST=0.0.0.0
PORT=3001

PROXY_API_KEY=proxy-please-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-me

OPENAI_BASE_URL=https://api.openai.com/v1
# Comma-separated list of free API keys (with Data Sharing enabled)
OPENAI_SHARED_KEYS=sk-shared-key-1,sk-shared-key-2
# Optional paid master API key (failsafe fallback)
OPENAI_MASTER_KEY=sk-paid-master-key

# Daily quotas per free key
KEY_DAILY_TOKEN_LIMIT=950000
KEY_DAILY_REQ_LIMIT=4800

# Server options
OPENAI_DEFAULT_MODEL=gpt-4o-mini
REQUEST_TIMEOUT_MS=90000
KEY_COOLDOWN_MS=60000
MAX_RETRIES=2
SQLITE_PATH=./proxy.db
